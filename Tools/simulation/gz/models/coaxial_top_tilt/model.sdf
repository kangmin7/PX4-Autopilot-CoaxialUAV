<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='coaxial_top_tilt'>
    <!--
      Cylinder-body coaxial UAV (Poongsan-style).

      Kinematic chain:
        base_link  ──(fixed)──────────────  rotor_0  (lower, CW,  motor 0)
        base_link  ── tilt_pitch_joint (Y)  ── tilt_pitch_link
                       tilt_pitch_link  ── tilt_roll_joint (X)  ── tilt_roll_link
                           tilt_roll_link  ──(spin)──  rotor_1  (upper, CCW, motor 1)

      Only the upper rotor tilts.

      All cylinder sections share r=0.050 m (uniform cylinder shape).
      Body column = 40 cm.  model pose z=0.140.

      Model-frame layout (base_link = centre of lower body):
        z=−0.100  Lower body bottom
        z=+0.100  Lower body top  /  bottom rotor  (50 % of 40 cm body)
        z=+0.260  Middle body top /  top rotor     (90 % of 40 cm body)
        z=+0.300  Top cap tip
        z=−0.135  Feet  (world 0.140−0.135=0.005 m clearance)

      Prop visual pose centres the blade hub on the shaft axis:
        scale=1.3 → hub at mesh-local (0.026, 0.173, 0.019)
        pose = −1.3×(0.026, 0.173, 0.019) = (−0.0338, −0.2249, −0.0246)
    -->
    <pose>0 0 0.140 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ================================================================
         BASE LINK
         ================================================================ -->
    <link name="base_link">
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0133</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0133</iyy>
          <iyz>0</iyz>
          <izz>0.0132</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />

      <!-- ── LOWER BODY  z=−0.100 to z=+0.100  (20 cm) ── -->
      <visual name="lower_body">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.200</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.22 0.25 0.15 1</ambient>
          <diffuse>0.28 0.30 0.18 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>

      <!-- ── MIDDLE BODY  z=+0.100 to z=+0.260  (16 cm) ── -->
      <visual name="middle_body">
        <pose>0 0 0.180 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.160</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.22 0.25 0.15 1</ambient>
          <diffuse>0.28 0.30 0.18 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>

      <!-- ── TOP CAP  z=+0.260 to z=+0.300  (4 cm) ── -->
      <visual name="top_cap">
        <pose>0 0 0.280 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.040</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.18 0.18 0.18 1</diffuse>
          <specular>0.08 0.08 0.08 1</specular>
        </material>
      </visual>

      <!--
        Landing legs — three diagonal tubes at 0°/120°/240°.

        Leg geometry:
          Start (body side near bottom): (0.050, 0, −0.065)
          End   (foot):                  (0.100, 0, −0.135)
          Vector: (0.050, 0, −0.070), length = 0.0860 m
          Midpoint: (0.075, 0, −0.100)
          Pitch R_y: atan2(0.050/0.0860, −0.070/0.0860) = 2.521 rad
        Yaw rotates each leg to 0°/120°/240°.
      -->
      <visual name="leg_0">
        <pose>0.075 0 -0.100 0 2.521 0</pose>
        <geometry>
          <cylinder>
            <radius>0.010</radius>
            <length>0.0860</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="leg_1">
        <pose>-0.0375 0.06495 -0.100 0 2.521 2.094</pose>
        <geometry>
          <cylinder>
            <radius>0.010</radius>
            <length>0.0860</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="leg_2">
        <pose>-0.0375 -0.06495 -0.100 0 2.521 -2.094</pose>
        <geometry>
          <cylinder>
            <radius>0.010</radius>
            <length>0.0860</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <!--
        Ground skids — tangential box at each foot.
        yaw = π/2 + α:  foot_0=1.5708  foot_1=3.665  foot_2=5.760
      -->
      <visual name="foot_0">
        <pose>0.100 0 -0.135 0 0 1.5708</pose>
        <geometry>
          <box><size>0.06 0.010 0.008</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="foot_1">
        <pose>-0.050 0.08660 -0.135 0 0 3.665</pose>
        <geometry>
          <box><size>0.06 0.010 0.008</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <visual name="foot_2">
        <pose>-0.050 -0.08660 -0.135 0 0 5.760</pose>
        <geometry>
          <box><size>0.06 0.010 0.008</size></box>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

      <!-- Body collision — single cylinder covering full 40 cm column -->
      <collision name="body_collision">
        <pose>0 0 0.100 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.400</length>
          </cylinder>
        </geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>

      <!-- Foot collisions -->
      <collision name="foot_0_collision">
        <pose>0.100 0 -0.135 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.008</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>
      <collision name="foot_1_collision">
        <pose>-0.050 0.08660 -0.135 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.008</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>
      <collision name="foot_2_collision">
        <pose>-0.050 -0.08660 -0.135 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.008</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>

      <!-- Sensors -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian"><mean>0</mean><stddev>3</stddev></noise>
          </pressure>
        </air_pressure>
      </sensor>
      <sensor name="magnetometer_sensor" type="magnetometer">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer>
          <x><noise type="gaussian"><stddev>0.0001</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.0001</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.0001</stddev></noise></z>
        </magnetometer>
      </sensor>
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.00686</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <!-- ================================================================
         TILT ASSEMBLY — inside middle body at z=0.180
         rotor_1 is 0.08 m above gimbal centre (z=0.260).
         ================================================================ -->

    <link name="tilt_pitch_link">
      <pose>0 0 0.180 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-05</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-05</iyy><iyz>0</iyz>
          <izz>1e-05</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />
    </link>
    <joint name="tilt_pitch_joint" type="revolute">
      <parent>base_link</parent>
      <child>tilt_pitch_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.5236</lower>
          <upper>0.5236</upper>
        </limit>
        <dynamics>
          <friction>0.1</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <link name="tilt_roll_link">
      <pose>0 0 0.180 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-05</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-05</iyy><iyz>0</iyz>
          <izz>1e-05</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />
    </link>
    <joint name="tilt_roll_joint" type="revolute">
      <parent>tilt_pitch_link</parent>
      <child>tilt_roll_link</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-0.5236</lower>
          <upper>0.5236</upper>
        </limit>
        <dynamics>
          <friction>0.1</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- ================================================================
         ROTOR 0 — lower, CW, motor 0
         z=0.100  →  world 0.140+0.100=0.240 m  (50 % of 40 cm body)
         Parent: base_link (does NOT tilt).
         ================================================================ -->
    <link name="rotor_0">
      <pose>0 0 0.100 0 0 0</pose>
      <inertial>
        <mass>0.016076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.6115851691700804e-05</iyy><iyz>0</iyz>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />
      <visual name="rotor_0_visual">
        <pose>-0.0338 -0.2249 -0.0246 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1.3 1.3 1.3</scale>
            <uri>model://x500_base/meshes/1345_prop_cw.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <visual name="rotor_0_motor_bell">
        <pose>0 0 -0.032 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://x500_base/meshes/5010Bell.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="rotor_0_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.4289 0.0260 0.0013</size></box>
        </geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
      </axis>
    </joint>

    <!-- ================================================================
         ROTOR 1 — upper, CCW, motor 1
         z=0.260  →  world 0.140+0.260=0.400 m  (90 % of 40 cm body)
         Parent: tilt_roll_link (TILTS with gimbal).
         ================================================================ -->
    <link name="rotor_1">
      <pose>0 0 0.260 0 0 0</pose>
      <inertial>
        <mass>0.016076923076923075</mass>
        <inertia>
          <ixx>3.8464910483993325e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.6115851691700804e-05</iyy><iyz>0</iyz>
          <izz>2.649858234714004e-05</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />
      <visual name="rotor_1_visual">
        <pose>-0.0338 -0.2249 -0.0246 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1.3 1.3 1.3</scale>
            <uri>model://x500_base/meshes/1345_prop_ccw.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <visual name="rotor_1_motor_bell">
        <pose>0 0 -0.032 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://x500_base/meshes/5010Bell.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="rotor_1_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.4289 0.0260 0.0013</size></box>
        </geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode /></friction>
        </surface>
      </collision>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>tilt_roll_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
      </axis>
    </joint>

    <!-- ================================================================
         MOTOR PLUGINS
         ================================================================ -->

    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.71e-05</motorConstant>
      <momentConstant>0.032</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>1.6128e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>2e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>1.71e-05</motorConstant>
      <momentConstant>0.032</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>1.6128e-04</rotorDragCoefficient>
      <rollingMomentCoefficient>2e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- ================================================================
         TILT SERVO PLUGINS
         ================================================================ -->

    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_pitch_joint</joint_name>
      <sub_topic>servo_0</sub_topic>
      <p_gain>10</p_gain>
      <i_gain>0</i_gain>
      <d_gain>0</d_gain>
      <i_max>0.0</i_max>
      <i_min>0.0</i_min>
      <cmd_max>2</cmd_max>
      <cmd_min>-2</cmd_min>
      <err_max>0.2</err_max>
    </plugin>

    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_roll_joint</joint_name>
      <sub_topic>servo_1</sub_topic>
      <p_gain>10</p_gain>
      <i_gain>0</i_gain>
      <d_gain>0</d_gain>
      <i_max>0.0</i_max>
      <i_min>0.0</i_min>
      <cmd_max>2</cmd_max>
      <cmd_min>-2</cmd_min>
      <err_max>0.2</err_max>
    </plugin>

  </model>
</sdf>
